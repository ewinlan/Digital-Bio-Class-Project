# make a directory for read counts

mkdir -p read_counts

#!/bin/bash
#SBATCH -J featurecounts
#SBATCH -A c01988
#SBATCH -p general
#SBATCH -N 1
#SBATCH -n 8
#SBATCH --mem=16G
#SBATCH -t 04:00:00
#SBATCH -o featurecounts_%j.out
#SBATCH -e featurecounts_%j.err

# Activate conda
source /N/u/ewinlan/Quartz/miniconda3/etc/profile.d/conda.sh
conda activate /N/u/ewinlan/Quartz/miniconda3/envs/rnaseq

cd Class_Project

# Paths
BAM_DIR="aligned_reads"
ANNOTATION="genome_files/annotation.gtf"
OUT_DIR="Class_Project/read_counts"

echo "Job started at: $(date)"
echo "Working directory: $(pwd)"

# Collect BAM files
BAMS=$(ls "$BAM_DIR"/*.bam)

# Run featureCounts
featureCounts \
  -a "$ANNOTATION" \
  -o "$OUT_DIR/counts.tsv" \
  -t gene \
  -g gene_id \
  --largestOverlap \
  --readExtension3 150 \
  --primary \
  -s 2 \
  -T 8 \
  $BAMS

echo "Job finished at: $(date)"

# count number of uniquely mapped reads 

head SRR23261282_pass_Log.final.out

