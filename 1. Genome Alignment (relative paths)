# align reads to reference
# I submitted this as a job using the following script:

#!/bin/bash
#SBATCH -J star_align
#SBATCH -A c01988
#SBATCH -p general
#SBATCH -N 1
#SBATCH -n 8
#SBATCH --mem=32G
#SBATCH -t 08:00:00
#SBATCH -o star_align_%j.out
#SBATCH -e star_align_%j.err

cd Class_Project

conda activate /N/u/ewinlan/Quartz/miniconda3/envs/rnaseq

GENOME_DIR="genome_files/genome_index"
FASTQ_DIR="fastq_files"
OUT_DIR="aligned_reads"

echo "Job started at: $(date)"
echo "Working directory: $(pwd)"
echo "Genome index: $GENOME_DIR"
echo "FASTQ directory: $FASTQ_DIR"
echo "Output directory: $OUT_DIR"

for FASTQ in "$FASTQ_DIR"/*.fastq; do
    BASENAME=$(basename "$FASTQ" .fastq)
    PREFIX="$OUT_DIR/${BASENAME}_"

    echo "Aligning $FASTQ"

    STAR \
      --runThreadN 8 \
      --outFilterMultimapNmax 1 \
      --outFilterScoreMinOverLread 0.66 \
      --outFilterMismatchNmax 10 \
      --outFilterMismatchNoverLmax 0.3 \
      --runMode alignReads \
      --genomeDir "$GENOME_DIR" \
      --readFilesIn "$FASTQ" \
      --outFileNamePrefix "$PREFIX" \
      --outSAMattributes All \
      --outSAMtype BAM SortedByCoordinate
done

echo "Job finished at: $(date)"

# index the resulting BAM files 
# do this inside of directory containing the BAM files

# Loop through BAM files
for BAM in "$BAM_DIR"/*.bam; do
    samtools index "$BAM"
done

