# ssh into quartz, request compute node, change into slate or scratch
# Minicona install
wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh

bash Miniconda3-latest-Linux-x86_64.sh

# SRA tools install

conda install -c bioconda sra-tools

# make a class project directory, this is my working directory for this project.

mkdir -p Class_Project

cd Class_Project

# create an environment for rnaseq 

conda create -n rnaseq -c conda-forge -c bioconda entrez-direct sra-tools==3.1.1 fastqc seqtk star samtools subread

# activate rnaseq environment 

conda activate rnaseq

# Download files from GEO
# To do this, go to GEO, look up your accession (GSE223919 in this case), then click the run selector link at the bottom of page
# Then, write down the SRR files you want to download
# in terminal, use prefetch to download files one by one, or use a for loop:

prefetch SRR23261298
prefetch SRR23261295
prefetch SRR23261292
prefetch SRR23261290
prefetch SRR23261288
prefetch SRR23261286
prefetch SRR23261284
prefetch SRR23261282

for srr in SRR23261286 SRR23261288 SRR23261290 SRR23261292 SRR23261295 SRR23261298; do
    echo "Processing $srr"

    fastq-dump \
        --outdir Class_Project/fastq_files \
        --skip-technical \
        --readids \
        --read-filter pass \
        --dumpbase \
        --split-3 \
        --clip \
        "$srr"

    echo "Finished $srr"
done
