# ssh into quartz
# Minicona install
wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh

bash Miniconda3-latest-Linux-x86_64.sh

# SRA tools install

conda install -c bioconda sra-tools

# Go to slate

cd /N/slate/ewinlan

# make a class project directory

mkdir Class_Project

# create an environment for rnaseq 

conda create -n rnaseq -c conda-forge -c bioconda entrez-direct sra-tools==3.4.1 fastqc seqtk star samtools subread

# activate rnaseq environment 

conda activate rnaseq

# Download files from GEO
# To do this, go to GEO, look up your accession (GSE223919 in this case), then click the run selector link at the bottom of page
# Then, write down the SRR files you want to download
# in terminal, use prefetch to download files one by one, or use for loop:


prefetch SRR23261295
prefetch SRR23261292
