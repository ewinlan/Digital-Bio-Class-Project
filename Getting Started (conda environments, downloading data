# Minicona install
wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh

bash Miniconda3-latest-Linux-x86_64.sh

# SRA tools install

conda install -c bioconda sra-tools

# Go to slate

cd /N/slate/ewinlan

# make a class project directory

mkdir Class_Project

# create an environment for rnaseq 

conda create -n rnaseq -c conda-forge -c bioconda entrez-direct sra-tools==2.9.6 fastqc seqtk star samtools subread

# activate rnaseq environment 

conda activate rnaseq

