# obtain fastq files... if personal rnaseq environment is not working, use class environment
# I submitted the following job script:
#!/bin/bash
#SBATCH --account=c01988
#SBATCH --time=08:00:00
#SBATCH --job-name=fastq_dump
#SBATCH --output=fastq_dump_%j.out
#SBATCH --error=fastq_dump_%j.err

### Load conda and activate your environment
module load conda
conda activate /N/scratch/chriscs/Public/Conda_032726_QUARTZ/envs/Db/

### Go to working directory (important!)
cd /N/slate/ewinlan/Class_Project/

### Convert SRR files to FASTQ
for srr in SRR23261286 SRR23261288 SRR23261290 SRR23261292 SRR23261295 SRR23261298
do
    echo "Processing $srr"
    fastq-dump --outdir /N/slate/ewinlan/Class_Project/fastq_files \
               --skip-technical \
               --readids \
               --read-filter pass \
               --dumpbase \
               --split-3 \
               --clip \
               "$srr"
done

echo "Done."
